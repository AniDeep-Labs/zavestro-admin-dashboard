# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.zavestro.in
VITE_ENV=development

# ── Sentry ────────────────────────────────────────────────────────────────────
# Same project as backend. Get DSN from sentry.io → zavestro-backend → Settings → SDK Setup
VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── Datadog RUM ───────────────────────────────────────────────────────────────
# Create RUM app at us5.datadoghq.com → UX Monitoring → RUM Applications → New Application
VITE_DD_APPLICATION_ID=
VITE_DD_CLIENT_TOKEN=
VITE_DD_SITE=us5.datadoghq.com

# ── ConfigCat ─────────────────────────────────────────────────────────────────
# Test env key for local dev, Production env key for prod build
VITE_CONFIGCAT_SDK_KEY=configcat-sdk-1/_6feCP9erEqPejRD2EkB5w/Vp1uPh-2fUmm29w3FPmrHA

# ── Build info ────────────────────────────────────────────────────────────────
VITE_COMMIT_SHA=local
